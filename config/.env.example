FITBIT_CLIENT_ID=replace-with-fitbit-client-id
FITBIT_CLIENT_SECRET=replace-with-fitbit-client-secret
FITBIT_REDIRECT_URI=http://localhost:8501/oauth/callback
FITBIT_ACCESS_TOKEN=
FITBIT_REFRESH_TOKEN=
FITBIT_TOKEN_EXPIRES_AT=
FITBIT_USER_ID=-
FITBIT_SCOPES=sleep,heartrate,oxygen_saturation,respiratory_rate
FITBIT_TIMEOUT_SECONDS=30
FITBIT_RETRY_ATTEMPTS=3
FITBIT_BACKOFF_FACTOR=1.5
FITBIT_TOKEN_EXPIRY_BUFFER_SECONDS=60
FITBIT_AUTO_REFRESH=true
FITBIT_MAX_RATE_LIMIT_WAIT_SECONDS=120
FITBIT_ACCEPT_LANGUAGE=en_US
FITBIT_ACCEPT_LOCALE=en_US
FITBIT_TOKEN_CACHE_PATH=data/processed/fitbit_token_cache.json
DATABASE_URL=mysql+aiomysql://user:password@mysql:3306/sleep_score_db?charset=utf8mb4&collation=utf8mb4_unicode_ci
